{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [
    "tsconfig.base.json",
    "pnpm-workspace.yaml",
    ".node-version"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.test.*"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "DATABASE_URL",
        "SERVER_HOST",
        "SERVER_PORT",
        "WEB_ORIGIN",
        "AI_PROVIDER",
        "SANDBOX_PROVIDER"
      ]
    }
  }
}
