{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "WriteCredentialSecretsOnly",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:CreateSecret",
        "secretsmanager:PutSecretValue",
        "secretsmanager:DeleteSecret",
        "secretsmanager:TagResource"
      ],
      "Resource": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:effect-agent/credentials/*"
    }
  ]
}
